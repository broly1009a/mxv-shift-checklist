//// ============================================================
//// MXV SHIFT CHECKLIST - DATABASE SCHEMA (DBML)
//// Hệ Thống Số Hóa Checklist Ca Trực Vận Hành MXV
//// ------------------------------------------------------------
//// Docs: https://dbml.dbdiagram.io/docs
//// Nguồn: NestJS / Mongoose Schemas (MongoDB)
//// Phiên bản: v2.1.0-PROD-MONGO (Agile Backlog Align Ready)
//// Ngày: 23 tháng 06, 2026
//// ============================================================

// ==========================================
// 1. Phân hệ Tổ chức & Nhân sự (Core Org)
// ==========================================

Table divisions {
  id         varchar(24) [pk, note: 'MongoDB ObjectId']
  name       varchar     [not null, note: 'Tên ban/khối, e.g. Ban Vận hành IT']
  code       varchar     [not null, unique, note: 'Mã khối, e.g. IT_DIVISION, TRADE_DIVISION']
  createdAt  timestamp   [note: 'Auto-generated by Mongoose timestamps']
  updatedAt  timestamp   [note: 'Auto-generated by Mongoose timestamps']

  Indexes {
    code [unique, name: 'idx_divisions_code']
  }
}

Table departments {
  id          varchar(24) [pk, note: 'MongoDB ObjectId']
  name        varchar     [not null, note: 'Tên phòng ban, e.g. IT Vận Hành Core']
  code        varchar     [not null, unique, note: 'Mã bộ phận, e.g. IT_CORE, RE_OPS, MARKET_SURV']
  divisionId  varchar(24) [ref: > divisions.id, note: 'Khối quản lý']
  createdAt   timestamp
  updatedAt   timestamp

  Indexes {
    code [unique, name: 'idx_departments_code']
  }
}

Enum user_role {
  ADMIN             [note: 'Quản trị hệ thống']
  CHAIRMAN          [note: 'Chủ tịch - read only']
  CEO               [note: 'Tổng giám đốc - read only']
  DIVISION_DIRECTOR [note: 'Giám đốc ban - read only']
  DEPARTMENT_HEAD   [note: 'Trưởng phòng - maker/checker']
  STAFF             [note: 'Nhân viên ca trực']
}

Enum user_theme {
  dark
  light
}

Table users {
  id            varchar(24) [pk, note: 'MongoDB ObjectId']
  username      varchar     [not null, unique, note: 'Tên đăng nhập, e.g. sonhh']
  passwordHash  varchar     [not null, note: 'Mật khẩu mã hóa bcrypt']
  fullName      varchar     [not null, note: 'Họ và tên đầy đủ']
  departmentId  varchar(24) [ref: > departments.id, note: 'Phòng ban (nullable)']
  divisionId    varchar(24) [ref: > divisions.id, note: 'Ban/khối (nullable)']
  role          user_role   [not null, default: 'STAFF']
  isActive      boolean     [not null, default: false, note: 'Tài khoản đang hoạt động?']

  // Embedded settings object (flattened)
  "settings.theme"                    user_theme [default: 'dark']
  "settings.autoRefreshInterval"      int        [default: 30, note: 'Giây']
  "settings.telegramNotifications"    boolean    [default: true]
  "settings.telegramChatId"           varchar    [default: '', note: 'Telegram Chat ID']
  "settings.alertThresholdMinutes"    int        [default: 15, note: 'Phút cảnh báo deadline']

  createdAt   timestamp
  updatedAt   timestamp

  Indexes {
    username [unique, name: 'idx_users_username']
  }
}

// ==========================================
// 2. Phân hệ Cấu hình Ca trực & SLA động (Shift Slot & SLA Config)
// ==========================================

Table shift_slots {
  id                 varchar(24) [pk, note: 'MongoDB ObjectId']
  departmentId       varchar(24) [ref: > departments.id, not null]
  shiftName          varchar     [not null, note: 'Tên ca trực, e.g. Ca 1, Ca 2']
  startTime          varchar     [not null, note: 'Giờ bắt đầu ca trực, format HH:mm, e.g. 05:00']
  endTime            varchar     [not null, note: 'Giờ kết thúc ca trực, format HH:mm, e.g. 13:00']
  gracePeriodMinutes int         [not null, default: 0, note: 'Thời gian ân hạn trước khi tính trễ SLA']
  createdAt          timestamp
  updatedAt          timestamp

  Indexes {
    (departmentId, shiftName) [name: 'idx_shift_slots_dept_name']
  }
}

Enum session_type {
  OPEN   [note: 'Phiên mở cửa - đầu ngày']
  DURING [note: 'Phiên trong phiên - trong ngày']
  CLOSE  [note: 'Phiên kết thúc - cuối ngày']
}

Enum task_priority {
  LOW      [note: 'Thấp']
  MEDIUM   [note: 'Trung bình']
  HIGH     [note: 'Cao']
  CRITICAL [note: 'Khẩn cấp']
}

Enum sla_type {
  FIXED_TIME          [note: 'Mốc giờ cứng, e.g. 07:30']
  DYNAMIC_AFTER_TASK  [note: 'Thời hạn động tính từ lúc task phụ thuộc hoàn thành']
}

// Embedded sub-document: ChecklistTemplateTask
// (Nằm trong mảng tasks[] của checklist_templates)
Table "checklist_templates.tasks" as ChecklistTemplateTask {
  taskId            varchar       [pk, note: 'Định danh tác vụ, e.g. it_open_snapshot']
  taskName          varchar       [not null, note: 'Nội dung đầu việc chi tiết']
  sessionType       session_type  [not null, default: 'OPEN', note: 'OPEN, DURING, CLOSE']
  priority          task_priority [not null, default: 'MEDIUM']
  sortOrder         int           [not null, note: 'Thứ tự sắp xếp hiển thị']
  isActive          boolean       [not null, default: true, note: 'Task có đang hoạt động?']
  
  // Cấu hình trigger & SLA động
  triggerTime       varchar       [note: 'Giờ kích hoạt task, e.g. "05:00"']
  slaType           sla_type      [not null, default: 'FIXED_TIME']
  slaDeadline       varchar       [note: 'Mốc giờ deadline nếu FIXED_TIME, e.g. "07:30"']
  slaMinutes        int           [note: 'Số phút thực hiện sau task trước nếu DYNAMIC_AFTER_TASK']
  slaWindowStart    varchar       [note: 'Giờ bắt đầu khung thời gian SLA, e.g. "06:00"']
  slaWindowEnd      varchar       [note: 'Giờ kết thúc khung thời gian SLA, e.g. "07:00"']
  
  // Ràng buộc & Nghiệp vụ phát sinh
  dependsOnTaskIds  varchar       [note: 'JSON array chứa danh sách các taskId bắt buộc hoàn tất trước']
  actionDescription varchar       [note: 'Mô tả chi tiết hành động nghiệp vụ cần thực hiện']
  exceptionCode     varchar       [note: 'Mã exception trigger tự động nếu task FAILED/Quá SLA, e.g. IF_EOD_SOD_ERROR']
  
  // Backup thủ công & Tần suất lặp lại (Recurring)
  isManualBackupAction           boolean [not null, default: false, note: 'Có phải tác vụ backup thủ công?']
  manualBackupActionDescription  varchar [note: 'Mô tả hướng dẫn xử lý backup thủ công']
  frequencyMinutes               int     [note: 'Tần suất lặp lại trong phiên tính bằng phút, e.g. 60 cho mỗi 1 giờ']
  recurrenceGroupId              varchar [note: 'Mã nhóm để gom các tác vụ lặp lại']
  
  // Thứ tự đóng ca & thứ tự ưu tiên backup
  blockingBeforeClose            boolean [not null, default: false, note: 'Bắt buộc hoàn thành trước khi close ca trực']
  backupPriority                 int     [not null, default: 0, note: 'Thứ tự ưu tiên backup, e.g. 1 cho CE và ACM (được ưu tiên trước)']
}

Table checklist_templates {
  id           varchar(24)  [pk, note: 'MongoDB ObjectId']
  title        varchar      [not null, note: 'Tiêu đề template, e.g. Mẫu trực IT Core']
  departmentId varchar(24)  [ref: > departments.id, not null]
  isActive     boolean      [not null, default: true]
  version      int          [not null, default: 1]
  // tasks: ChecklistTemplateTask[] — embedded array
  createdAt    timestamp
  updatedAt    timestamp

  Indexes {
    (departmentId, isActive) [name: 'idx_templates_query']
  }
}

// ==========================================
// 3. Phân hệ Vận hành ca trực (Shift Execution & Logs)
// ==========================================

Enum shift_log_status {
  PENDING   [note: 'Ca trực đang thực hiện']
  COMPLETED [note: 'Ca trực đã hoàn thành và bàn giao']
}

Enum task_status {
  PENDING
  PASSED
  FAILED
  SKIPPED
  NEEDS_ATTENTION
}

Enum sla_status {
  COMPLIANT
  OVERDUE
}

// Embedded sub-document: ShiftLogDetailReconciliationResult
// (Kết quả đối chiếu chéo các nền tảng của US 1.3)
Table "shift_logs.details.reconciliation_results" as ShiftLogDetailReconciliationResult {
  platform        varchar [pk, note: 'Tên nền tảng đối chiếu, e.g. M_SYSTEM, CQG, ACM']
  status          varchar [not null, note: 'Trạng thái đối chiếu, e.g. MATCHED, MISMATCHED']
  settlementPrice varchar [note: 'Giá thanh toán (chỉ điền đối với EOD task)']
  note            varchar [note: 'Ghi chú đối chiếu']
  evidenceUrl     varchar [note: 'Đường dẫn ảnh/file bằng chứng đối chiếu']
}

// Embedded sub-document: ShiftLogDetail
// (Snapshot chứa thông tin task thực tế, nằm trong details[])
Table "shift_logs.details" as ShiftLogDetail {
  taskId            varchar       [pk]
  taskNameSnapshot  varchar       [not null]
  sessionTypeSnapshot session_type [not null]
  prioritySnapshot  task_priority [not null]
  status            task_status   [not null, default: 'PENDING']
  
  // Snapshot thông tin SLA & Quy trình
  triggerTimeSnapshot           varchar
  slaTypeSnapshot               sla_type
  slaDeadlineSnapshot           varchar
  slaMinutesSnapshot            int
  slaWindowStartSnapshot        varchar
  slaWindowEndSnapshot          varchar
  dependsOnTaskIdsSnapshot      varchar
  exceptionCodeSnapshot         varchar
  
  // Snapshot cấu hình backup & lặp lại
  isManualBackupActionSnapshot          boolean
  manualBackupActionDescSnapshot        varchar
  frequencyMinutesSnapshot              int
  recurrenceGroupIdSnapshot             varchar
  scheduledAt                           timestamp   [note: 'Mốc thời gian dự kiến thực thi (đối với task lặp lại)']
  blockingBeforeCloseSnapshot           boolean
  backupPrioritySnapshot                int
  
  // Trạng thái vận hành thực tế
  startedAt         timestamp     [note: 'Thời điểm bắt đầu thực hiện task']
  completedAt       timestamp     [note: 'Thời điểm hoàn thành task']
  failedAt          timestamp     [note: 'Thời điểm đánh dấu failed']
  skippedAt         timestamp     [note: 'Thời điểm đánh dấu skipped']
  updatedBy         varchar(24)   [ref: > users.id, note: 'Người cập nhật cuối']
  resultNote        varchar       [note: 'Ghi chú kỹ thuật khi hoàn thành']
  
  // Phục vụ cho tác vụ đính kèm báo cáo BGS (US 2.5)
  reportType        varchar       [note: 'Loại báo cáo, e.g. DSGD, TTM']
  deliveryChannel   varchar       [note: 'Kênh gửi báo cáo, e.g. WHATSAPP, MANUAL']
  fileLocation      varchar       [note: 'Đường dẫn file báo cáo đã tải lên hoặc link drive']
  sentAt            timestamp     [note: 'Mốc thời gian gửi báo cáo thực tế']

  // checkResults: ShiftLogDetailReconciliationResult[] — embedded array
  
  // Trạng thái SLA
  slaStatus         sla_status    [not null, default: 'COMPLIANT']
  slaBreachedAt     timestamp     [note: 'Thời điểm phát hiện vi phạm SLA']
}

Table shift_logs {
  id                 varchar(24)      [pk, note: 'MongoDB ObjectId']
  templateId         varchar(24)      [ref: > checklist_templates.id, not null, note: 'Template snapshot gốc']
  userId             varchar(24)      [ref: > users.id, not null, note: 'Nhân viên trực ca (người nhận ca)']
  shiftDate          varchar          [not null, note: 'Ngày trực, format YYYY-MM-DD']
  status             shift_log_status [not null, default: 'PENDING']
  progressPercentage float            [not null, default: 0.0]
  // details: ShiftLogDetail[] — embedded array
  closedBy           varchar(24)      [ref: > users.id, note: 'Người xác nhận đóng ca']
  closedAt           timestamp
  handoverNote       varchar          [note: 'Nội dung bàn giao ca']
  createdAt          timestamp
  updatedAt          timestamp

  Indexes {
    shiftDate [name: 'idx_shiftlog_date']
    (templateId, shiftDate) [name: 'idx_shiftlog_temp_date']
  }
}

// ==========================================
// 4. Phân hệ Quản lý Sự cố & Khiếu nại (Incidents & Exceptions)
// ==========================================

Enum incident_type {
  SYSTEM_OR_NETWORK_ERROR  [note: 'Sự cố mạng / hạ tầng / API']
  UNBALANCED_DATA          [note: 'Lệch dữ liệu lệnh / giao dịch giữa các nền tảng']
  MEMBER_REQUEST_OR_COMPLAINT [note: 'Yêu cầu / khiếu nại từ Thành viên Kinh doanh (TVKD)']
  CHECKLIST_EXCEPTION      [note: 'Lỗi phát sinh tự động từ checklist (e.g. EOD/SOD lỗi, quá SLA)']
}

Enum incident_severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

Enum incident_status {
  PENDING       [note: 'Mới phát hiện']
  INVESTIGATING [note: 'Đang điều tra nguyên nhân']
  RESOLVED      [note: 'Đã khắc phục tạm thời / hoàn thành báo cáo']
  CLOSED        [note: 'Đã đóng và kiểm tra chéo']
}

Enum incident_root_cause {
  MISSING_CONFIGURATION [note: 'Thiếu cấu hình tham số hệ thống']
  MESSAGE_SYNC_LOSS     [note: 'Mất đồng bộ tin nhắn/lệnh API']
  API_DISCONNECT        [note: 'Mất kết nối API bên thứ ba']
  HARDWARE_FAILURE      [note: 'Lỗi phần cứng / mạng vật lý']
  SOFTWARE_BUG          [note: 'Lỗi phần mềm M-System/CQG/ACM']
  HUMAN_ERROR           [note: 'Lỗi thao tác con người']
  OTHER
}

Enum incident_source {
  TEAMS
  EMAIL
  PHONE
  SYSTEM_LOG
  OTHER
}

Table incidents {
  id                varchar(24)       [pk, note: 'MongoDB ObjectId']
  shiftLogId        varchar(24)       [ref: > shift_logs.id, note: 'Liên kết ca trực xảy ra sự cố (nullable)']
  taskId            varchar           [note: 'Mã task liên quan nếu phát sinh từ checklist (nullable)']
  code              varchar           [note: 'Mã exception từ checklist, e.g. IF_SNAPSHOT_FAILED (nullable)']
  type              incident_type     [not null]
  title             varchar           [not null, note: 'Tiêu đề ngắn gọn sự cố']
  description       varchar           [note: 'Mô tả chi tiết hiện tượng']
  severity          incident_severity [not null, default: 'MEDIUM']
  status            incident_status   [not null, default: 'PENDING']
  
  // SLA của Sự cố
  slaDeadlineAt     timestamp         [note: 'Hạn chót phải xử lý xong sự cố']
  detectedAt        timestamp         [not null, note: 'Thời điểm phát hiện sự cố']
  resolvedAt        timestamp         [note: 'Thời điểm giải quyết xong']
  resolvedBy        varchar(24)       [ref: > users.id]
  
  // Xử lý kỹ thuật & đối chiếu
  rootCause         incident_root_cause
  technicalCause    varchar           [note: 'Nguyên nhân chi tiết phía hệ thống']
  remediationAction varchar           [note: 'Hành động khắc phục và phục hồi dữ liệu']
  requiredAction    varchar           [note: 'Hành động bắt buộc (e.g. phối hợp với Newgen xử lý kết chuyển dữ liệu)']
  affectedAccounts  varchar           [note: 'JSON array chứa danh sách TKGD bị ảnh hưởng, e.g. ["001C123456"]']
  
  // Tiếp nhận & Giải quyết khiếu nại TVKD (US 4.3)
  sourceChannel     incident_source   [note: 'Kênh tiếp nhận khiếu nại (TEAMS, EMAIL...)']
  receivedAt        timestamp         [note: 'Thời điểm tiếp nhận thông tin từ TVKD']
  acceptedAt        timestamp         [note: 'Thời điểm Operator bắt đầu tiếp nhận và tìm nguyên nhân']
  responseSummary   varchar           [note: 'Nội dung phản hồi chính thức cho TVKD']
  
  createdAt         timestamp
  updatedAt         timestamp

  Indexes {
    status [name: 'idx_incidents_status']
    type [name: 'idx_incidents_type']
    shiftLogId [name: 'idx_incidents_shiftlog']
  }
}

Enum timeline_actor {
  OPERATOR
  SYSTEM
  BOT
}

Table incident_timelines {
  id                varchar(24)     [pk]
  incidentId        varchar(24)     [ref: > incidents.id, not null]
  actorId           varchar(24)     [ref: > users.id, note: 'Người thực hiện (nullable nếu là SYSTEM/BOT)']
  actorType         timeline_actor  [not null, default: 'OPERATOR']
  actionDescription varchar         [not null, note: 'Mô tả hành động, e.g. "Chuyển trạng thái sang INVESTIGATING"']
  beforeState       varchar         [note: 'Lưu log trạng thái trước khi đổi (JSON String)']
  afterState        varchar         [note: 'Lưu log trạng thái sau khi đổi (JSON String)']
  createdAt         timestamp
}

// ==========================================
// 5. Phân hệ Phê duyệt Thay đổi (Maker-Checker & Approvals)
// ==========================================

Enum request_status {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

Table margin_change_requests {
  id             varchar(24)    [pk, note: 'MongoDB ObjectId']
  shiftLogId     varchar(24)    [ref: > shift_logs.id, not null]
  commodity      varchar        [not null, note: 'Mã hàng hóa, e.g. XAUUSD']
  oldMargin      varchar        [not null, note: 'Mức ký quỹ cũ']
  newMargin      varchar        [not null, note: 'Mức ký quỹ đề xuất mới']
  effectiveSession session_type [not null, default: 'OPEN', note: 'Phiên áp dụng thay đổi']
  effectiveDate  varchar        [not null, note: 'Ngày áp dụng, format YYYY-MM-DD']
  status         request_status [not null, default: 'PENDING_APPROVAL']
  
  // Maker-Checker audit fields
  createdBy      varchar(24)    [ref: > users.id, not null, note: 'Nhân viên đề xuất (Maker - Ca 1)']
  approvedBy     varchar(24)    [ref: > users.id, note: 'Trưởng bộ phận phê duyệt (Checker - Ca 2)']
  approvedAt     timestamp
  rejectReason   varchar        [note: 'Lý do từ chối nếu bị REJECTED']
  
  createdAt      timestamp
  updatedAt      timestamp

  Indexes {
    status [name: 'idx_margin_req_status']
  }
}

// ==========================================
// 6. Phân hệ Quản lý Hợp đồng & Đáo hạn (Contracts & Maturity)
// ==========================================

Enum contract_type {
  FUTURES
  SPREADS
  ACM
}

Enum contract_status {
  ACTIVE
  MATURED
  INACTIVE
}

Table contract_catalog {
  id           varchar(24)     [pk]
  contractCode varchar         [not null, unique, note: 'Mã hợp đồng, e.g. GLEQ26']
  commodity    varchar         [not null, note: 'Mã mặt hàng']
  type         contract_type   [not null]
  maturityDate varchar         [not null, note: 'Ngày đáo hạn YYYY-MM-DD']
  status       contract_status [not null, default: 'ACTIVE']
  createdAt    timestamp
  updatedAt    timestamp

  Indexes {
    contractCode [unique, name: 'idx_contracts_code']
  }
}

Enum maturity_action_type {
  NOTIFIED_TVKD
  CANCELLED_PENDING_ORDERS
  FORCE_CLOSED_POSITIONS
}

Table contract_maturity_actions {
  id          varchar(24)          [pk]
  contractId  varchar(24)          [ref: > contract_catalog.id, not null]
  shiftLogId  varchar(24)          [ref: > shift_logs.id, not null]
  actionType  maturity_action_type  [not null]
  performedBy varchar(24)          [ref: > users.id, not null]
  evidence    varchar              [note: 'Bằng chứng thực thi (e.g. log hệ thống, URL ảnh chụp)']
  performedAt timestamp
}

// ==========================================
// 7. Phân hệ Cảnh báo & Gửi tin (Notifications Rules & Logs)
// ==========================================

Table notification_channels {
  id         varchar(24) [pk]
  name       varchar     [not null, note: 'Tên kênh nhận tin, e.g. Telegram Group IT']
  type       varchar     [not null, note: 'e.g. TELEGRAM, EMAIL, WEB_PUSH, SMS']
  config     varchar     [not null, note: 'Thông số kỹ thuật kênh dưới dạng JSON string (token, chatId, smtp server...)']
  isActive   boolean     [not null, default: true]
  createdAt  timestamp
  updatedAt  timestamp
}

Table notification_rules {
  id            varchar(24)  [pk]
  departmentId  varchar(24)  [ref: > departments.id, not null]
  eventType     varchar      [not null, note: 'Mã loại sự kiện, e.g. SLA_BREACH, INCIDENT_NEW']
  severityLimit varchar      [note: 'Mức nghiêm trọng tối thiểu để trigger, e.g. HIGH']
  channelId     varchar(24)  [ref: > notification_channels.id, not null, note: 'Liên kết kênh gửi tin']
  recipients    varchar      [not null, note: 'JSON array chứa email/chatId trực tiếp nhận tin']
  isActive      boolean      [not null, default: true]
  createdAt     timestamp
  updatedAt     timestamp
}

Enum notification_status {
  SENT
  FAILED
}

Table notification_logs {
  id           varchar(24)         [pk]
  ruleId       varchar(24)         [ref: > notification_rules.id, not null]
  recipient    varchar             [not null, note: 'Email hoặc Telegram Chat ID']
  channel      varchar             [not null, note: 'Kênh gửi (sao chép từ channel type để làm lịch sử)']
  content      varchar             [not null, note: 'Nội dung tin đã gửi']
  status       notification_status [not null]
  errorMessage varchar             [note: 'Chi tiết lỗi nếu gửi thất bại']
  createdAt    timestamp
}

// ==========================================
// 8. Phân hệ Xuất Bản báo cáo (Export Reports Metadata)
// ==========================================

Table report_exports {
  id                 varchar(24) [pk]
  incidentId         varchar(24) [ref: > incidents.id, note: 'Sự cố liên quan (nullable)']
  shiftLogId         varchar(24) [ref: > shift_logs.id, note: 'Ca trực liên quan (nullable)']
  reportTemplateCode varchar     [not null, note: 'Mẫu báo cáo xuất bản, e.g. 01/QT/TVH']
  fileUrl            varchar     [not null, note: 'Đường dẫn tải file báo cáo đã xuất bản']
  fileType           varchar     [not null, note: 'Định dạng file, e.g. PDF, CSV, DOCX']
  exportedBy         varchar(24) [ref: > users.id, not null]
  createdAt          timestamp
}

// ==========================================
// 9. Phân hệ Hậu kiểm & Nhật ký thao tác (Audit Logs)
// ==========================================

Enum audit_action {
  CHECK
  UNCHECK
  NOTE_UPDATE
  SYSTEM_TRIGGER
}

Table audit_logs {
  id         varchar(24)  [pk, note: 'MongoDB ObjectId']
  shiftLogId varchar(24)  [ref: > shift_logs.id, not null]
  taskId     varchar      [not null]
  taskName   varchar      [not null]
  userId     varchar(24)  [ref: > users.id, not null, note: 'Người thực hiện (hệ thống/nhân viên)']
  action     audit_action [not null]
  details    varchar      [not null, note: 'Log chi tiết thao tác (JSON String)']
  createdAt  timestamp

  Indexes {
    shiftLogId [name: 'idx_audit_logs_shift']
    (shiftLogId, taskId) [name: 'idx_audit_logs_shift_task']
  }
}
