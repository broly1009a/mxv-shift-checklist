//// ============================================================
//// MXV SHIFT CHECKLIST - DATABASE SCHEMA (DBML)
//// Hệ Thống Số Hóa Checklist Ca Trực Vận Hành MXV
//// ------------------------------------------------------------
//// Docs: https://dbml.dbdiagram.io/docs
//// Nguồn: NestJS / Mongoose Schemas (MongoDB)
//// Phiên bản: v1.2.0-PROD-MONGO
//// Ngày: 11 tháng 06, 2026
//// ============================================================

//// -- LEVEL 1: Collections & Embedded Documents
//// -- Lưu ý: MongoDB dùng _id (ObjectId). DBML dùng varchar(24)
////           để biểu diễn ObjectId dưới dạng hex string.

// -------------------------------------------------------
// 1. Collection: divisions (Ban / Khối)
// -------------------------------------------------------
Table divisions {
  id         varchar(24) [pk, note: 'MongoDB ObjectId']
  name       varchar     [not null, note: 'Tên ban/khối, e.g. Ban Vận hành IT']
  code       varchar     [not null, unique, note: 'Mã khối, e.g. IT_DIVISION, TRADE_DIVISION']
  createdAt  timestamp   [note: 'Auto-generated by Mongoose timestamps']
  updatedAt  timestamp   [note: 'Auto-generated by Mongoose timestamps']

  Indexes {
    code [unique, name: 'idx_divisions_code']
  }
}

// -------------------------------------------------------
// 2. Collection: departments (Phòng ban / Bộ phận trực)
// -------------------------------------------------------
Table departments {
  id          varchar(24) [pk, note: 'MongoDB ObjectId']
  name        varchar     [not null, note: 'Tên phòng ban, e.g. IT Vận Hành Core']
  code        varchar     [not null, unique, note: 'Mã bộ phận, e.g. IT_CORE, RE_OPS, MARKET_SURV']
  divisionId  varchar(24) [ref: > divisions.id, note: 'Khối quản lý (nullable)']
  createdAt   timestamp   [note: 'Auto-generated by Mongoose timestamps']
  updatedAt   timestamp   [note: 'Auto-generated by Mongoose timestamps']

  Indexes {
    code [unique, name: 'idx_departments_code']
  }
}

// -------------------------------------------------------
// 3. Collection: users (Tài khoản nhân sự)
// -------------------------------------------------------
Enum user_role {
  ADMIN           [note: 'Quản trị hệ thống']
  CHAIRMAN        [note: 'Chủ tịch - read only']
  CEO             [note: 'Tổng giám đốc - read only']
  DIVISION_DIRECTOR [note: 'Giám đốc ban - read only']
  DEPARTMENT_HEAD [note: 'Trưởng phòng - read only']
  STAFF           [note: 'Nhân viên ca trực']
}

Enum user_theme {
  dark
  light
}

Table users {
  id            varchar(24) [pk, note: 'MongoDB ObjectId']
  username      varchar     [not null, unique, note: 'Tên đăng nhập, e.g. sonhh']
  passwordHash  varchar     [not null, note: 'Mật khẩu mã hóa bcrypt ($2b$10$...)']
  fullName      varchar     [not null, note: 'Họ và tên đầy đủ']
  departmentId  varchar(24) [ref: > departments.id, note: 'Phòng ban (nullable)']
  divisionId    varchar(24) [ref: > divisions.id, note: 'Ban/khối (nullable)']
  role          user_role   [not null, default: 'STAFF']
  isActive      boolean     [not null, default: false, note: 'Tài khoản đang hoạt động?']

  // Embedded settings object (flattened)
  "settings.theme"                    user_theme [default: 'dark']
  "settings.autoRefreshInterval"      int        [default: 30, note: 'Giây']
  "settings.telegramNotifications"    boolean    [default: true]
  "settings.telegramChatId"           varchar    [default: '', note: 'Telegram Chat ID']
  "settings.alertThresholdMinutes"    int        [default: 15, note: 'Phút cảnh báo deadline']

  createdAt   timestamp
  updatedAt   timestamp

  Indexes {
    username [unique, name: 'idx_users_username']
  }
}

// -------------------------------------------------------
// 4. Collection: checklist_templates (Mẫu cấu hình việc động)
// -------------------------------------------------------
Enum session_type {
  OPEN   [note: 'Phiên mở cửa - trước giờ giao dịch']
  DURING [note: 'Phiên trong phiên - đang giao dịch']
  CLOSE  [note: 'Phiên kết thúc - sau giờ giao dịch']
}

Enum task_priority {
  LOW      [note: 'Thấp']
  MEDIUM   [note: 'Trung bình']
  HIGH     [note: 'Cao']
  CRITICAL [note: 'Khẩn cấp - ảnh hưởng trực tiếp hệ thống']
}

// Embedded sub-document: TaskItem
// (Nằm trong mảng tasks[] của checklist_templates)
Table "checklist_templates.tasks" as TaskItem {
  taskId    varchar [pk, note: 'Chuỗi định danh tác vụ, e.g. it_open_01']
  taskName  varchar [not null, note: 'Mô tả đầu việc nghiệp vụ']
  priority  task_priority [not null]
  sortOrder int     [not null, note: 'Thứ tự hiển thị trong phiên']
  deadline  varchar [note: 'Giờ deadline tùy chọn, e.g. "08:30"']
}

Table checklist_templates {
  id           varchar(24)  [pk, note: 'MongoDB ObjectId']
  title        varchar      [not null, note: 'Tiêu đề mẫu, e.g. Checklist mở cửa phiên giao dịch']
  departmentId varchar(24)  [ref: > departments.id, not null, note: 'Phòng ban sở hữu mẫu']
  sessionType  session_type [not null, note: 'Loại phiên áp dụng']
  // tasks: TaskItem[] — embedded array, xem bảng "checklist_templates.tasks"
  createdAt    timestamp
  updatedAt    timestamp

  Indexes {
    (departmentId, sessionType) [name: 'idx_template_dept_session']
  }
}

// -------------------------------------------------------
// 5. Collection: shift_logs (Nhật ký ca trực chạy thực tế)
// -------------------------------------------------------
Enum shift_log_status {
  PENDING   [note: 'Ca trực đang tiến hành']
  COMPLETED [note: 'Ca trực đã hoàn thành và bàn giao']
}

// Embedded sub-document: ShiftLogDetail
// (Snapshot của TaskItem khi mở ca, nằm trong details[])
Table "shift_logs.details" as ShiftLogDetail {
  taskId           varchar [pk, note: 'taskId snapshot từ template']
  taskNameSnapshot varchar [not null, note: 'Tên tác vụ tại thời điểm mở ca (immutable)']
  prioritySnapshot varchar [not null, note: 'Độ ưu tiên tại thời điểm mở ca (immutable)']
  isChecked        boolean [not null, default: false, note: 'Đã tích chọn hoàn thành?']
  checkedAt        timestamp [note: 'Thời điểm tích chọn (null nếu chưa check)']
  updatedBy        varchar(24) [ref: > users.id, note: 'User thực hiện toggle (nullable)']
  note             varchar [note: 'Ghi chú kỹ thuật của nhân viên (nullable)']
  deadlineSnapshot varchar [note: 'Deadline snapshot từ template (nullable)']
}

Table shift_logs {
  id                 varchar(24)      [pk, note: 'MongoDB ObjectId']
  templateId         varchar(24)      [ref: > checklist_templates.id, not null, note: 'Template gốc dùng để clone']
  userId             varchar(24)      [ref: > users.id, not null, note: 'Nhân viên khởi tạo ca trực']
  shiftDate          varchar          [not null, note: 'Ngày ca trực, format YYYY-MM-DD']
  status             shift_log_status [not null, default: 'PENDING']
  progressPercentage float            [not null, default: 0.0, note: '% hoàn thành tính từ details']
  // details: ShiftLogDetail[] — embedded array, xem bảng "shift_logs.details"
  closedBy           varchar(24)      [ref: > users.id, note: 'User đóng ca (nullable)']
  closedAt           timestamp        [note: 'Thời điểm đóng ca (nullable)']
  handoverNote       varchar          [note: 'Ghi chú bàn giao ca (nullable)']
  createdAt          timestamp
  updatedAt          timestamp

  Indexes {
    shiftDate        [name: 'idx_shiftlog_date']
    (templateId, shiftDate) [name: 'idx_shiftlog_template_date']
  }
}

// -------------------------------------------------------
// 6. Collection: audit_logs (Lịch sử thao tác hậu kiểm)
// -------------------------------------------------------
Enum audit_action {
  CHECK       [note: 'Nhân viên tích chọn hoàn thành tác vụ']
  UNCHECK     [note: 'Nhân viên bỏ tích tác vụ']
  NOTE_UPDATE [note: 'Cập nhật ghi chú kỹ thuật']
}

Table audit_logs {
  id         varchar(24) [pk, note: 'MongoDB ObjectId']
  shiftLogId varchar(24) [ref: > shift_logs.id, not null, note: 'Ca trực liên quan']
  taskId     varchar     [not null, note: 'ID tác vụ bị tác động']
  taskName   varchar     [not null, note: 'Tên tác vụ tại thời điểm thao tác']
  userId     varchar(24) [ref: > users.id, not null, note: 'Nhân viên thực hiện hành động']
  action     audit_action [not null]
  details    varchar     [not null, note: 'Mô tả chi tiết thao tác (JSON string)']
  createdAt  timestamp   [note: 'Chỉ có createdAt, không có updatedAt']

  Indexes {
    shiftLogId [name: 'idx_auditlog_shiftlog']
    (shiftLogId, taskId) [name: 'idx_auditlog_shift_task']
  }
}

//----------------------------------------------//
//// -- Relationships Summary
//// divisions     1 -< departments          (1 khối có nhiều phòng ban)
//// divisions     1 -< users                (1 khối có nhiều user)
//// departments   1 -< users                (1 phòng có nhiều nhân sự)
//// departments   1 -< checklist_templates  (1 phòng có nhiều mẫu)
//// checklist_templates 1 -< shift_logs     (1 mẫu sinh nhiều ca trực)
//// users         1 -< shift_logs           (1 user mở nhiều ca)
//// shift_logs    1 -< audit_logs           (1 ca có nhiều bản ghi audit)
//// users         1 -< audit_logs           (1 user có nhiều thao tác)

